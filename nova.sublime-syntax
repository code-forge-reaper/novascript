%YAML 1.2
---
name: NovaScript
file_extensions:
  - nova
scope: source.nova

contexts:
  main:
    - include: comments
    - include: strings
    - include: numbers
    - include: function_definitions
    - include: namespace_definition
    - include: keywords
    - include: builtins
    - include: decorators
    - include: using_stmt
    - include: function_calls
    - include: operators
    - include: types
    - include: custom_types
    - include: enum_definition
    - include: class
    - match: \b[a-zA-Z_]\w*\b
      scope: variable.other.nova
  class:
    - match: \b(class|object|inherits|static|super)\b
      scope: keyword.declaration.nova
  comments:
    - match: '//.*$'
      scope: comment.line.double-slash.nova
    - match: '/\*'
      scope: comment.block.nova
      push:
        - meta_scope: comment.block.nova
        - match: '.*\*/'
          pop: true
        - match: '.+'

  strings:
    - match: '"'
      scope: punctuation.definition.string.begin.nova
      push: double_quoted_string
    - match: "'"
      scope: punctuation.definition.string.begin.nova
      push: single_quoted_string

  double_quoted_string:
    - meta_scope: string.quoted.double.nova
    - match: '\\.'
      scope: constant.character.escape.nova
    - match: '"'
      scope: punctuation.definition.string.end.nova
      pop: true

  single_quoted_string:
    - meta_scope: string.quoted.single.nova
    - match: '\\.'
      scope: constant.character.escape.nova
    - match: "'"
      scope: punctuation.definition.string.end.nova
      pop: true

  numbers:
    # hex numbers: 0xFF, 0xDEAD_BEEF
    - match: \b0[xX][0-9a-fA-F_]+\b
      scope: constant.numeric.hex.nova

    # unicode literals: 0u41, 0u1F600
    - match: \b0[uU][0-9a-fA-F_]+\b
      scope: constant.character.unicode.nova

    # decimal / float
    - match: \b-?\d+(\.\d+)?\b
      scope: constant.numeric.nova

  keywords:
    # Declarations
    - match: \b(var|const|new|with|func|def|return|import|define)\b
      scope: keyword.declaration.nova
      # import "some module" as alias
    - match: \bas\b\s+(\w+)
      captures:
        1: entity.name.label.nova
      scope: keyword.declaration.nova


    # Control flow
    - match: \b(for|break|continue|foreach|while|until|do|in|end|else|elseif|if|test|failed|defer)\b
      scope: keyword.control.flow.nova

    # Types
    # like: var x number
    # type Entity = {move:function}
    - match: \b(string|number|function|bool|void)\b
      scope: storage.type.nova

    # builtin
    - match: \b(undefined|nil|NaN)\b
      scope: constant.language.nova

  namespace_definition:
    - match: \bscope\b\s+(\w+)
      captures:
        1: entity.name.namespace.nova
      scope: keyword.declaration.nova
  using_stmt:
    # using [module.a, module.b, ...] | using {v: 24}
    - match: "\\b(using)\\b\\s*(\\[|{)"
      captures:
        1: keyword.declaration.nova
        2: punctuation.section.brackets.begin.nova
      push:
        - meta_scope: meta.using.nova
        - include: using_stmt_array

    # using module.name.or.more
    - match: "\\b(using)\\b\\s+([A-Za-z_]\\w*(?:\\.[A-Za-z_]\\w*)*)"
      captures:
        1: keyword.declaration.nova
        2: entity.name.namespace.nova

  using_stmt_array:
    - meta_content_scope: meta.using.list.nova
    - match: "\\]"
      scope: punctuation.section.brackets.end.nova
      pop: true
    - match: "\\s*,\\s*"
      scope: punctuation.separator.comma.nova
    - match: "([A-Za-z_]\\w*(?:\\.[A-Za-z_]\\w*)*)"
      captures:
        1: entity.name.namespace.nova
    - match: "\\s+"
      scope: text.whitespace.nova
    - match: "."
      scope: invalid.illegal.nova


  function_definitions:
    - match: \bfunc\b\s+(\w+)
      captures:
        1: entity.name.function.nova
      scope: keyword.declaration.function.nova

  function_calls:
    - match: \b[a-zA-Z_]\w*(?=\s*\()
      scope: entity.name.function.nova

  decorators:
    - match: \@(\w+)
      captures:
        1: entity.name.function.nova

  custom_types:
    - match: \bdefine\b\s+(\w+)
      captures:
        1: entity.name.type.nova
      scope: keyword.declaration.nova

  enum_definition:
    # enum <name> { <values> }
    - match: \benum\b\s+(\w+)
      captures:
        1: entity.name.type.nova
      scope: keyword.declaration.nova

  builtins:
    - match: \b(true|false)\b
      scope: constant.language.nova

  types: # the "keyword.declaration.nova" is just here because i don't know what else to label it as
    - match: \b(switch|strict|case|default)\b
      captures:
        1: keyword.declaration.nova
      scope: keyword.declaration.nova

  operators:
    - match: ==|!=|<=|>=|\+=|-=|\*=|/=|&&|\|\||[=+\-*/<>!]
      scope: keyword.operator.nova
    - match: '[\(\)\[\]\{\}\.,:]'
      scope: punctuation.separator.nova
